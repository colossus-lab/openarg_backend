# ── OpenArg Backend — Environment Variables ─────────────────
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
#
# Generate secrets:
#   openssl rand -base64 32   (for NEXTAUTH_SECRET)
#   openssl rand -base64 24   (for BACKEND_API_KEY, ADMIN_API_KEY)
#   openssl rand -base64 32   (for POSTGRES_PASSWORD, REDIS_PASSWORD)
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=openarg
POSTGRES_PASSWORD=
POSTGRES_DB=openarg_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── AI Keys ───────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Frontend (NextAuth + Google OAuth) ────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://openarg.org
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=

# ── Security ─────────────────────────────────────────────────
BACKEND_API_KEY=
CORS_ALLOWED_ORIGINS=https://openarg.org
SANDBOX_DATABASE_URL=
SANDBOX_POSTGRES_PASSWORD=
ADMIN_EMAILS=

# ── Flower ───────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=

# ── App ───────────────────────────────────────────────────────
APP_ENV=prod

# ── Security Tuning (defaults are fine for most deployments) ──
# INJECTION_THRESHOLD=0.6
# CACHE_SIMILARITY_THRESHOLD=0.92
# SANDBOX_MAX_ROWS=1000
# SANDBOX_TABLE_PREFIX=cache_
# SANDBOX_TIMEOUT_MS=10000
